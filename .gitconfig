[user]
	name = philip82148
	email = 92205270+philip82148@users.noreply.github.com
[alias]
    a = add
    c = commit
    cm = commit -m
    ad = commit --amend --no-edit
    adm = commit --amend -m
    b = branch
    co = checkout
    cob = checkout -b
    l = log
    lp = log --graph --pretty=format:'%C(yellow)%h%C(cyan)%d%Creset %s %C(green)- %an, %cr%Creset'
    lpn = log --graph --pretty=format:'%C(yellow)%h%C(cyan)%d%Creset %s %C(green)- %an, %cr%Creset' --name-status
    s = stash
    sl = stash list
    su = stash -u
    sum = stash -um
    suk = stash -uk
    sukm = stash -ukm
    sp = stash pop
    ri = rebase -i
    rc = rebase --continue
    ra = rebase --abort
[init]
	defaultBranch = main
